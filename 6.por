programa 
{
  funcao inicio()  
  {
    real n1, n2

    escreva("digite o primeiro numero: ")
    leia(n1)

    escreva("digite o segundo numero: ")
    leia(n2)

    se(n1 > n2)
  { 
     escreva("\no maior numero eh: ")
     escreva(n1)

  } 
  senao
  { 
    escreva("\no maior numero eh: ")
    escreva(n2)
    }    
  }
}
