programa 
{
  funcao inicio() 
  {
    caracter letra

    escreva("digite uma letra: ")
    leia(letra)
     
     se (letra == 'a' ou letra == 'e' ou letra == 'i' ou letra == 'o' ou letra =='u') 

  { 
    escreva("\na letra eh uma vogal") 
  }
  senao
  { 
    escreva("\na letra eh uma consoante.")

    }
  }
}
